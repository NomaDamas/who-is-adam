# Offline/fake mode
WHO_IS_ADAM_OFFLINE=0
WHO_IS_ADAM_FIXED_RUN_TIMESTAMP=
WHO_IS_ADAM_RANDOM_SEED=0

# LLM provider: fake, openai, anthropic, custom_http
WHO_IS_ADAM_LLM_PROVIDER=fake
WHO_IS_ADAM_LLM_MODEL=
WHO_IS_ADAM_LLM_API_KEY=
WHO_IS_ADAM_LLM_BASE_URL=
WHO_IS_ADAM_LLM_TIMEOUT_SECONDS=60
WHO_IS_ADAM_LLM_MAX_RETRIES=1
WHO_IS_ADAM_LLM_SUPPORTS_JSON_SCHEMA=1

# OpenReview public evidence provider
WHO_IS_ADAM_OPENREVIEW_BASE_URL=https://api2.openreview.net
WHO_IS_ADAM_OPENREVIEW_TIMEOUT_SECONDS=30
WHO_IS_ADAM_OPENREVIEW_MAX_RETRIES=2
WHO_IS_ADAM_OPENREVIEW_API_KEY=

# Semantic Scholar citation provider
WHO_IS_ADAM_SEMANTIC_SCHOLAR_API_KEY=
WHO_IS_ADAM_SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
WHO_IS_ADAM_SEMANTIC_SCHOLAR_TIMEOUT_SECONDS=30
WHO_IS_ADAM_SEMANTIC_SCHOLAR_MAX_RETRIES=2

# Crossref citation provider
WHO_IS_ADAM_CROSSREF_BASE_URL=https://api.crossref.org
WHO_IS_ADAM_CROSSREF_MAILTO=
WHO_IS_ADAM_CROSSREF_TIMEOUT_SECONDS=30
WHO_IS_ADAM_CROSSREF_MAX_RETRIES=2

# arXiv citation provider
WHO_IS_ADAM_ARXIV_BASE_URL=https://export.arxiv.org/api/query
WHO_IS_ADAM_ARXIV_TIMEOUT_SECONDS=30
WHO_IS_ADAM_ARXIV_MAX_RETRIES=2

# Optional OCR/Tesseract
WHO_IS_ADAM_OCR_ENABLED=0
WHO_IS_ADAM_TESSERACT_CMD=
